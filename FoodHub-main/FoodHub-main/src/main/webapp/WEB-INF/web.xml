<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="https://jakarta.ee/xml/ns/jakartaee" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd" id="WebApp_ID" version="6.0">
  <display-name>JEE1</display-name>
  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
    <welcome-file>index.jsp</welcome-file>
    <welcome-file>index.htm</welcome-file>
    <welcome-file>index.xhtml</welcome-file>
    <welcome-file>default.html</welcome-file>
    <welcome-file>default.jsp</welcome-file>
    <welcome-file>default.htm</welcome-file>
    <welcome-file>default.xhtml</welcome-file>
    <welcome-file>login.jsp</welcome-file>
    <welcome-file>NewFile.html</welcome-file>
    <welcome-file>register.jsp</welcome-file>
    <welcome-file>home.jsp</welcome-file>
    </welcome-file-list>
    <!-- Registration Servlet -->

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.tap.Servlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/callingServlet</url-pattern>
    </servlet-mapping>
    
    <!-- Login Servlet -->

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.tap.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    
    <!-- Cart Servlet -->

<servlet>
    <servlet-name>CartServlet</servlet-name>
    <servlet-class>com.tap.CartServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>CartServlet</servlet-name>
    <url-pattern>/CartServlet</url-pattern>
</servlet-mapping>
  
  
  
 </web-app>
